  color: var(--tpi-muted);
}

.tpi-card-meta {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 10px;
  margin: 0;
}

.tpi-card-meta div {
  padding: 12px;
  border-radius: 16px;
  background: rgba(23, 86, 214, 0.04);
}

.tpi-card-meta dt {
  margin-bottom: 6px;
  color: var(--tpi-muted);
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.tpi-card-meta dd {
  margin: 0;
  line-height: 1.5;
}

.tpi-card-footer {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
  padding-top: 2px;
}

.tpi-card-details-toggle {
  min-height: 36px;
  padding: 0 12px;
  border: 1px solid rgba(23, 86, 214, 0.12);
  border-radius: 999px;
  background: #10203e;
  color: white;
  font-size: 0.84rem;
  font-weight: 700;
  cursor: pointer;
}

.tpi-card-footer-hint {
  color: var(--tpi-muted);
  font-size: 0.8rem;
}

.tpi-card-details {
  display: grid;
  gap: 14px;
  margin-top: 6px;
  padding-top: 14px;
  border-top: 1px solid var(--tpi-line);
}

.tpi-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.tpi-detail-grid article {
  padding: 12px;
  border-radius: 16px;
  background: rgba(23, 86, 214, 0.04);
  border: 1px solid rgba(23, 86, 214, 0.08);
}

.tpi-detail-grid article span {
  display: block;
  margin-bottom: 6px;
  color: var(--tpi-muted);
  font-size: 0.76rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.tpi-detail-grid article strong {
  font-size: 0.92rem;
  line-height: 1.45;
}

.tpi-detail-section {
  display: grid;
  gap: 10px;
}

.tpi-detail-section h4 {
  margin: 0;
  font-size: 0.95rem;
}

.tpi-inline-values {
  display: grid;
  gap: 8px;
}

.tpi-inline-values span {
  padding: 10px 12px;
  border-radius: 14px;
  background: rgba(23, 32, 51, 0.05);
  color: var(--tpi-ink);
}

.tpi-tag-groups {
  display: grid;
  gap: 12px;
}

.tpi-tag-group {
  display: grid;
  gap: 8px;
  padding: 12px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(23, 32, 51, 0.06);
}

.tpi-tag-group-header {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
}

.tpi-tag-group-header small {
  color: var(--tpi-muted);
  font-weight: 600;
}

.tpi-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tpi-toolbar-row {
  display: grid;
  gap: 12px;
  margin-top: 16px;
}

.tpi-display-options,
.tpi-category-strip {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  padding: 14px 16px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(23, 32, 51, 0.08);
}

.tpi-display-options > span,
.tpi-category-strip > span {
  color: var(--tpi-muted);
  font-weight: 700;
}

.tpi-option-toggle {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 10px;
  border-radius: 999px;
  background: rgba(23, 86, 214, 0.06);
  border: 1px solid rgba(23, 86, 214, 0.08);
  cursor: pointer;
  font-size: 0.84rem;
  font-weight: 600;
}

.tpi-option-toggle input {
  accent-color: var(--tpi-accent);
}

.tpi-category-strip button {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 36px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid rgba(23, 32, 51, 0.08);
  background: #ffffff;
  color: var(--tpi-ink);
  cursor: pointer;
}

.tpi-category-strip button strong {
  min-width: 20px;
  padding: 2px 6px;
  border-radius: 999px;
  background: rgba(23, 86, 214, 0.08);
  color: var(--tpi-accent);
  font-size: 0.74rem;
}

.tpi-category-strip button.active {
  background: var(--tpi-accent);
  border-color: var(--tpi-accent);
  color: white;
}

.tpi-category-strip button.active strong {
  background: rgba(255, 255, 255, 0.18);
  color: white;
}

.tpi-list-mini-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
  color: var(--tpi-muted);
  font-size: 0.82rem;
}

.tpi-list-mini-stats span {
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(23, 32, 51, 0.05);
}

.tpi-table-shell {
  margin-top: 24px;
  overflow: auto;
  border-radius: 20px;
  border: 1px solid var(--tpi-line);
}

.tpiTable {
  width: 100%;
  border-collapse: collapse;
  background: white;
}

.tpiTable th,
.tpiTable td {
  padding: 14px 16px;
  border-bottom: 1px solid rgba(23, 32, 51, 0.08);
  text-align: left;
  vertical-align: top;
}

.tpiTable th {
  position: sticky;
  top: 0;
  background: #10203e;
  color: white;
  white-space: nowrap;
}

.tpiTable tr:nth-child(even) {
  background: rgba(23, 86, 214, 0.03);
}

.tpi-form-card {
  width: 100%;
}

.tpi-form-topline {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: start;
}

.tpi-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  margin-top: 22px;
}

.tpi-form-section {
  padding: 18px;
  border-radius: 22px;
  background: rgba(23, 86, 214, 0.04);
  border: 1px solid rgba(23, 86, 214, 0.08);
}

.tpi-form-section h4 {
  margin: 0 0 16px;
  font-size: 1rem;
}

.tpi-form-section-wide {
  grid-column: span 2;
}

.tpi-form-date-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.containerForm {
  display: flex;
  justify-content: center;
  align-items: stretch;
  margin-top: 18px;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 14px;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-row label {
  min-width: 120px;
  font-weight: 700;
}

.form-row input,
.form-row textarea {
  flex: 1;
}

.form-row.textarea {
  align-items: start;
}

.form-row.textarea textarea {
  min-height: 108px;
  resize: vertical;
}

.form-row.stacked {
  flex-direction: column;
  align-items: stretch;
  gap: 8px;
}

.form-row.stacked label {
  min-width: auto;
}

.save {
  justify-content: flex-end;
  margin-top: 22px;
}

.save button,
.tpi-import-actions button {
  min-width: 148px;
}

.save button:disabled,
.tpi-import-actions button:disabled {
  cursor: not-allowed;
  opacity: 0.6;
  transform: none;
  box-shadow: none;
}

#tools.tpi-management-tools {
  top: calc(var(--room-padding-top) - 32px);
  width: calc(100% - 28px);
  max-width: 1320px;
  left: 50%;
  transform: translateX(-50%);
  padding: 10px 14px;
  border-radius: 20px;
  background:
    linear-gradient(135deg, rgba(255, 249, 229, 0.94) 0%, rgba(236, 245, 255, 0.94) 100%);
  text-align: left;
}

.tpi-management-tools-shell {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto auto;
  gap: 10px;
  align-items: center;
}

.tpi-management-tools-copy {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.tpi-management-tools-copy strong {
  font-size: 1rem;
}

.tpi-management-tools-copy p {
  margin: 0;
  color: var(--tpi-muted);
}

.tpi-management-tools-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.tpi-management-tools-meta {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tpi-year-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 58px;
  min-height: 36px;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(16, 32, 62, 0.08);
  color: var(--tpi-ink);
  font-size: 0.92rem;
  font-weight: 700;
}

#tools.tpi-management-tools button {
  min-width: 122px;
  min-height: 38px;
  margin: 0;
  border-radius: 12px;
  border: 1px solid transparent;
  background: #10203e;
  color: white;
  font-size: 0.9rem;
  font-weight: 600;
}

#tools.tpi-management-tools #btImportTpi {
  background: #23644b;
}

#tools.tpi-management-tools #upArrowButton {
  min-width: 38px;
  width: 38px;
  padding: 0;
  background: rgba(16, 32, 62, 0.08);
  color: var(--tpi-ink);
  border-color: rgba(16, 32, 62, 0.08);
}

#tools.tpi-management-tools #upArrowButton span {
  font-size: 1rem;
  line-height: 1;
}

.tpi-import-panel {
  margin-top: 12px;
  padding: 14px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(23, 32, 51, 0.08);
}

.tpi-import-panel-header {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: start;
}

.tpi-import-form {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 12px;
}

.tpi-import-field {
  display: flex;
  flex-direction: column;
  gap: 8px;
  color: var(--tpi-muted);
}

.tpi-import-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  grid-column: span 2;
}

.tpi-management-state-card h3 {
  margin-top: 0;
  margin-bottom: 10px;
}

.tpi-management-state-card p {
  margin: 0;
  color: var(--tpi-muted);
}

.tpi-management-state-card.error {
  border-color: rgba(166, 59, 45, 0.18);
  background: rgba(255, 244, 242, 0.94);
}

.tpi-management-state-card.empty {
  text-align: center;
}

@media (max-width: 1080px) {
  .tpi-management-hero,
  .tpi-management-toolbar,
  .tpi-management-tools-shell,
  .tpi-import-panel-header,
  .tpi-form-topline,
  .tpi-management-editor-header,
  .tpi-list-header {
    grid-template-columns: 1fr;
    flex-direction: column;
  }

  .tpi-management-toolbar {
    grid-template-columns: 1fr;
  }

  .tpi-management-tools-shell {
    grid-template-columns: 1fr;
  }

  .tpi-form-grid,
  .tpi-import-form {
    grid-template-columns: 1fr;
  }

  .tpi-form-section-wide,
  .tpi-import-actions {
    grid-column: auto;
  }
}

@media (max-width: 768px) {
  .tpi-management-page {
    width: calc(100% - 18px);
    padding-bottom: 42px;
  }

  .tpi-management-hero,
  .tpi-management-toolbar,
  .tpi-management-editor-shell,
  .tpi-list-shell,
  .tpi-management-state-card,
  #tools.tpi-management-tools {
    border-radius: 20px;
  }

  .tpi-management-hero,
  .tpi-management-toolbar,
  .tpi-management-editor-shell,
  .tpi-list-shell,
  .tpi-management-state-card {
    padding: 18px;
  }

  .tpi-management-stats,
  .tpi-card-meta,
  .tpi-form-date-grid {
    grid-template-columns: 1fr;
  }

  .tpi-detail-grid {
    grid-template-columns: 1fr;
  }

  .form-row {
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
  }

  .form-row label {
    min-width: auto;
  }

  #tools.tpi-management-tools {
    width: calc(100% - 18px);
    padding: 10px;
  }

  .tpi-management-tools-actions,
  .tpi-import-actions,
  .save {
    flex-direction: column;
  }

  .tpi-list-header,
  .tpi-card-header,
  .tpi-card-footer,
  .tpi-tag-group-header {
    flex-direction: column;
    align-items: stretch;
  }

  #tools.tpi-management-tools button,
  .save button,
  .tpi-import-actions button,
  .tpi-card-edit,
  .tpi-table-edit {
    width: 100%;
  }

  .tpi-category-strip button,
  .tpi-option-toggle {
    width: 100%;
    justify-content: center;
  }
}
