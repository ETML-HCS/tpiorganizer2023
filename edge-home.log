}



.slot-date {

  font-weight: 600;

  color: #333;

}



.slot-time,

.slot-room,

.voter-role {

  color: #666;

}



/* Vote Actions */

.vote-actions {

  display: flex;

  gap: 8px;

  flex-wrap: wrap;

}



.vote-btn {

  flex: 1;

  min-width: 80px;

  padding: 10px 12px;

  border: 2px solid #ddd;

  border-radius: 8px;

  background: white;

  cursor: pointer;

  font-size: 0.85rem;

  font-weight: 500;

  transition: all 0.2s;

  display: flex;

  align-items: center;

  justify-content: center;

  gap: 5px;

}



.vote-btn:hover {

  transform: translateY(-2px);

  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);

}



.vote-btn.preferred {

  border-color: #bbdefb;

  color: #1565c0;

}



.vote-btn.preferred:hover,

.vote-btn.preferred.active {

  background: #2196f3;

  border-color: #2196f3;

  color: white;

}



.vote-btn.accepted {

  border-color: #c8e6c9;

  color: #2e7d32;

}



.vote-btn.accepted:hover,

.vote-btn.accepted.active {

  background: #4caf50;

  border-color: #4caf50;

  color: white;

}



.vote-btn.rejected {

  border-color: #ffcdd2;

  color: #c62828;

}



.vote-btn.rejected:hover,

.vote-btn.rejected.active {

  background: #f44336;

  border-color: #f44336;

  color: white;

}



/* Rejection Reason */

.rejection-reason {

  margin-top: 15px;

  padding-top: 15px;

  border-top: 1px dashed #ddd;

}



.rejection-reason label {

  display: block;

  font-size: 0.85rem;

  color: #666;

  margin-bottom: 8px;

}



.rejection-reason textarea {

  width: 100%;

  padding: 10px;

  border: 1px solid #ddd;

  border-radius: 6px;

  font-size: 0.9rem;

  resize: vertical;

  font-family: inherit;

}



.rejection-reason textarea:focus {

  outline: none;

  border-color: #f44336;

}



/* Card Footer */

.card-footer {

  display: flex;

  justify-content: flex-end;

  padding-top: 15px;

  border-top: 1px solid #e0e0e0;

}



.btn-submit-votes {

  padding: 12px 30px;

  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

  color: white;

  border: none;

  border-radius: 8px;

  font-size: 1rem;

  font-weight: 600;

  cursor: pointer;

  transition: all 0.2s;

  display: flex;

  align-items: center;

  gap: 10px;

}



.btn-submit-votes:hover:not(:disabled) {

  transform: translateY(-2px);

  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);

}



.btn-submit-votes:disabled {

  opacity: 0.6;

  cursor: not-allowed;

}



.spinner-small {

  width: 18px;

  height: 18px;

  border: 2px solid rgba(255, 255, 255, 0.3);

  border-top-color: white;

  border-radius: 50%;

  animation: spin 1s linear infinite;

}



@keyframes spin {

  to { transform: rotate(360deg); }

}



/* Responsive */

@media (max-width: 768px) {

  .panel-header {

    padding: 20px;

  }

  

  .panel-header h2 {

    font-size: 1.1rem;

  }

  

  .card-header {

    flex-direction: column;

    align-items: flex-start;

    gap: 10px;

  }

  

  .voting-meta {

    width: 100%;

    justify-content: space-between;

  }

  

  .slots-grid {

    grid-template-columns: 1fr;

  }

  

  .vote-actions {

    flex-direction: column;

  }

  

  .vote-btn {

    width: 100%;

  }

}

