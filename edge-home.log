}



.detail-section p {

  margin: 0;

  font-size: 0.9rem;

  color: #333;

}



/* Voting Info */

.voting-section {

  grid-column: span 2;

}



.votes-progress {

  background: #f0f0f0;

  border-radius: 8px;

  height: 30px;

  position: relative;

  overflow: hidden;

}



.progress-bar {

  height: 100%;

  background: linear-gradient(90deg, #4caf50, #8bc34a);

  border-radius: 8px;

  transition: width 0.3s;

}



.progress-text {

  position: absolute;

  top: 50%;

  left: 50%;

  transform: translate(-50%, -50%);

  font-size: 0.85rem;

  font-weight: 600;

  color: #333;

}



.voting-deadline {

  display: block;

  margin-top: 10px;

  font-size: 0.85rem;

  color: #666;

}



.voting-conflict {

  display: block;

