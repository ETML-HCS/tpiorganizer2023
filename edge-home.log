  box-shadow: 0 0 15px rgba(0, 0, 0, 0.3); /* Ombre portée */

  padding: 20px;

  z-index: 9999;

  max-width: min(420px, calc(100vw - 48px));

}



#popup-content {

  text-align: left; /* Alignement du texte à gauche */

}



#close-btn {

  position: absolute;

  top: 10px;

  right: 10px;

  cursor: pointer;

  color: #888; /* Couleur du bouton de fermeture */

  font-size: 18px; /* Taille de la police du bouton de fermeture */

}



/* Design liste tpiEval */

.evaluation-list {

  font-family: Arial, sans-serif;

  margin-bottom: 20px;

}



.evaluations-year {

  float: right;

  margin-top: -10px;

  margin-right: -10px;

  font-weight: bold;

}



.evaluation-items {

  list-style-type: none;

  padding: 0;

  display: grid;

  grid-template-columns: repeat(auto-fit, minmax(200px, 250px));

  gap: 13px;

}



.evaluation-item {

  background-color: #f9f9f9;

  border: 1px solid #ddd;

  border-radius: 6px;

  padding: 15px;

  box-shadow: 0 2px 2px rgba(0, 0, 0, 0.1);

}



.evaluation-ref {

  font-weight: bold;

