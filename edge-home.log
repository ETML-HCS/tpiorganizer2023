  font-weight: 700;
}

#tools.page-tools .page-tools-title {
  font-size: 0.82rem;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.15;
}

#tools.page-tools .page-tools-description {
  margin: 0;
  color: #475569;
  font-size: 0.7rem;
  line-height: 1.25;
}

#tools.page-tools .page-tools-meta,
#tools.page-tools .page-tools-actions {
  display: flex;
  align-items: center;
  gap: 3px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

#tools.page-tools .page-tools-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 24px;
  padding: 0 7px;
  border-radius: 999px;
  border: 1px solid rgba(100, 116, 139, 0.18);
  background: #e2e8f0;
  color: #334155;
  font-size: 0.7rem;
  font-weight: 700;
  white-space: nowrap;
}

#tools.page-tools .page-tools-body {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

#tools.page-tools .page-tools-navigation {
  display: flex;
  flex-wrap: nowrap;
  gap: 4px;
  padding-top: 0;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

#tools.page-tools .page-tools-navigation::-webkit-scrollbar {
  display: none;
}

#tools.page-tools .page-tools-navigation-link {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 0 7px;
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.22);
  background: rgba(255, 255, 255, 0.72);
  color: #334155;
  font-size: 0.67rem;
  font-weight: 700;
  text-decoration: none;
  white-space: nowrap;
}

#tools.page-tools .page-tools-navigation-link.active {
  background: linear-gradient(180deg, #edf4fb 0%, #dbeafe 100%);
  border-color: rgba(96, 165, 250, 0.55);
  color: #1e3a8a;
}

#tools.page-tools .page-tools-tabs {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 3px;
  padding: 2px;
  border: 1px solid #dbe4ec;
  border-radius: 16px;
  background: linear-gradient(180deg, #eef4fb 0%, #e9eff6 100%);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

#tools.page-tools .page-tools-tab {
  position: relative;
  width: 100%;
  min-width: 0;
  min-height: 30px;
  height: auto;
  margin: 0;
  padding: 2px 7px;
  border: 1px solid transparent;
  border-radius: 12px;
  background: transparent;
  color: #475569;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.01em;
  box-shadow: none;
  overflow: hidden;
}

#tools.page-tools .page-tools-tab:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.8);
  color: #0f172a;
}

#tools.page-tools .page-tools-tab.active {
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  color: #0f172a;
  border-color: rgba(148, 163, 184, 0.34);
  box-shadow: 0 10px 18px rgba(15, 23, 42, 0.08);
  transform: translateY(-1px);
}

#tools.page-tools .page-tools-tab.active::before {
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  background: linear-gradient(90deg, #2563eb 0%, #7c3aed 100%);
}

#tools.page-tools .page-tools-tab:focus-visible {
  outline: 2px solid #1756d6;
  outline-offset: 2px;
}

#tools.page-tools .page-tools-tab-icon {
  font-size: 0.8rem;
  line-height: 1;
}

#tools.page-tools .page-tools-tab-label {
  line-height: 1.1;
}

#tools.page-tools .page-tools-tab-badge {
  min-width: 16px;
  min-height: 16px;
  padding: 0 4px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.12);
  color: #1e3a8a;
  font-size: 0.6rem;
  font-weight: 800;
}

#tools.page-tools .page-tools-tab.active .page-tools-tab-badge {
  background: rgba(37, 99, 235, 0.08);
}

#tools.page-tools .page-tools-inline-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: end;
}

#tools.page-tools .page-tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 8px 10px;
  align-items: end;
}

#tools.page-tools .page-tools-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  min-width: 0;
}

#tools.page-tools .page-tools-field-action {
  justify-content: flex-end;
}

#tools.page-tools .page-tools-field-action .page-tools-action-btn {
  width: 100%;
}

#tools.page-tools .page-tools-field-label {
  font-size: 0.75rem;
  font-weight: 700;
  color: #475569;
}

#tools.page-tools .page-tools-field-control,
#tools.page-tools .page-tools-action-btn,
#tools.page-tools .page-tools-file-label {
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #cbd5e1;
  background: #ffffff;
  color: #0f172a;
  font-size: 0.84rem;
  font-weight: 600;
  transition: background-color 0.15s ease, border-color 0.15s ease,
    box-shadow 0.15s ease, transform 0.1s ease;
}

#tools.page-tools .page-tools-field-control {
  width: 100%;
  padding: 0 10px;
  box-sizing: border-box;
}

#tools.page-tools .page-tools-action-btn,
#tools.page-tools .page-tools-file-label {
  padding: 0 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
}

#tools.page-tools .page-tools-action-btn:hover:not(:disabled),
#tools.page-tools .page-tools-file-label:hover {
  transform: translateY(-1px);
  border-color: #94a3b8;
  box-shadow: 0 6px 14px rgba(15, 23, 42, 0.08);
}

#tools.page-tools .page-tools-action-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

#tools.page-tools .page-tools-action-btn.primary {
  background: #1756d6;
  border-color: #1756d6;
  color: #ffffff;
}

#tools.page-tools .page-tools-action-btn.primary:hover:not(:disabled) {
  background: #1249bb;
}

#tools.page-tools .page-tools-action-btn.secondary {
  background: #eef2f7;
  color: #334155;
}

#tools.page-tools .page-tools-action-btn.secondary:hover:not(:disabled) {
  background: #e2e8f0;
}

#tools.page-tools .page-tools-action-btn.success {
  background: #dcfce7;
  border-color: #86efac;
  color: #166534;
}

#tools.page-tools .page-tools-action-btn.success:hover:not(:disabled) {
  background: #bbf7d0;
}

#tools.page-tools .page-tools-file-label {
  background: #f1f5f9;
}

#tools.page-tools .collapse-toggle-mini {
  min-width: 38px;
  width: 38px;
  height: 38px;
  padding: 0;
  margin: 0;
  border: 1px solid rgba(51, 65, 85, 0.14);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.72);
  color: #334155;
  box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
}

#tools.page-tools .collapse-toggle-mini .collapse-toggle-icon {
  width: 8px;
  height: 8px;
}

#tools.page-tools .page-tools-file-label input {
  display: none;
}

#tools.page-tools .page-tools-note {
  margin: 0;
  color: #475569;
  font-size: 0.82rem;
  line-height: 1.4;
}

/*  permet d'afficher des informations sur le @media utilisés */
.media-indicator {
  display: none;
  position: fixed;

  bottom: 0;

  right: 0;

  background-color: rgba(0, 0, 0, 0.7);

  color: white;

  padding: 5px;

  font-size: 20px;

  z-index: 1000;

}



.form-group {

  margin-bottom: 20px;

}



.btn-primary {

  background-color: #007bff;

  color: #fff;

  border: none;

  padding: 10px 20px;

  border-radius: 5px;

  cursor: pointer;

}



.btn-primary:hover {

  background-color: #0056b3;

}



.list-group-item {

  margin-bottom: 10px;

  background-color: #f0f0f0;

  padding: 10px;

  border-radius: 5px;

}



/* Footer.css */

.footer {

  background-color: white;

  position: fixed;

  bottom: 0px;

  left: -42px;

  width: calc(100% + 40px);

  color: black; /* Couleur de texte par défaut */

  font-size: 12px;

 

  transition: color 0.3s; /* Ajout d'une transition sur la couleur */

  z-index: -1;

}



.footer-content {

  text-align: right;

}



.footer-content span{

  position: fixed;

  left: 2px;

}



.footer:hover {

  color: #6181ff; /* Couleur du texte au survol */

}



/* Media query pour les appareils avec une largeur maximale de 767px */

@media (max-width: 767px) {
  /* Réduire la taille de la police pour une meilleure lisibilité sur les petits écrans */
  body {
    font-size: 0.78rem;
  }



  #title{
    font-size: 11px;
    margin: 0;
    gap: 0;
  }

  #title {
    min-height: 34px;
    padding: 4px 8px 3px;
    gap: 8px;
  }

  .dateToday {
    gap: 6px;
    font-size: 0.72rem;
  }

  .logout-btn {
    height: 24px;
    padding: 0 8px;
    font-size: 0.7rem;
  }

  .collapse-toggle-label {
    display: none;
  }

  .collapse-toggle-header {
    min-height: 32px;
    padding: 0 12px;
  }

  #tools.planning-tools {
    padding: 8px;
  }

  #tools.planning-tools .page-tools-shell {
    max-height: 300px;
  }

  #tools.planning-tools button,
  #tools.planning-tools .planning-tools-file-label {
    min-width: 132px;
    height: 32px;
  }

  #tools.page-tools {
    padding: 6px 8px 8px;
  }

  #tools.page-tools .page-tools-shell {
    max-height: 48vh;
  }

  #tools.page-tools .page-tools-header {
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2px 4px;
  }

  #tools.page-tools .page-tools-navigation {
    gap: 3px;
  }

  #tools.page-tools .page-tools-navigation-link {
    height: 19px;
    padding: 0 6px;
    font-size: 0.65rem;
  }

  #tools.page-tools .page-tools-tabs {
    grid-template-columns: repeat(auto-fit, minmax(116px, 1fr));
    gap: 3px;
    padding: 2px;
  }

  #tools.page-tools .page-tools-tab {
    min-height: 32px;
    padding: 2px 7px;
    font-size: 0.7rem;
  }

  #tools.page-tools .page-tools-meta,
  #tools.page-tools .page-tools-actions {
    justify-content: flex-start;
  }

  #tools.page-tools .page-tools-action-btn,
  #tools.page-tools .page-tools-file-label,
  #tools.page-tools .page-tools-field-control {
    min-height: 32px;
  }

}
