  align-items: center;

  border: 1px solid #d6d9e0;

  border-radius: 10px;

  padding: 10px 12px;

  background: #f9fbff;

  transition: border-color 0.2s ease, box-shadow 0.2s ease;

}



.input-wrapper:focus-within {

  border-color: #2563eb;

  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);

}



