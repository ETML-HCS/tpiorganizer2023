  font-weight: bold;

  color: white;

  font-size: 14px; /* Légère augmentation de la taille de la police */

  border: none;

  border-radius: 4px; /* Ajout de coins arrondis */

  text-align: center; /* Centrage du texte horizontalement */

}



.btn_questionAdd {

  background-color: #16e42eed;

}



.btn_questionMinus {

  background-color: #ed2125ed;

}



.btn_questionMinus:hover,

.btn_questionAdd:hover,

.btn_Selected:hover {

