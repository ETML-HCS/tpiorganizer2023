  font-size: 0.8rem;

  font-weight: 500;

  transition: all 0.2s;

  margin-right: 5px;

}



.btn-vote {

  background: #e3f2fd;

  color: #1565c0;

}



.btn-vote:hover {

  background: #bbdefb;

}



.btn-resolve {

  background: #fff3e0;

  color: #e65100;

}



.btn-resolve:hover {

  background: #ffe0b2;

}



/* Details Row */

.tpi-details-row {

  background: #fafafa;

}



.tpi-details-row td {

  padding: 0;

}



.tpi-details {

  padding: 20px;

  display: grid;

  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));

  gap: 20px;

  border-left: 4px solid #2196f3;

  margin-left: 4px;

}



.detail-section {

  background: white;

