}



.col-3 {

  width: 60px;

  /* Longueur pour contenir un nombre de 0 à 3 */

}



.col-4 {

  width: auto;

  /* Longueur dynamique */

}



/* Styles pour masquer le contenu visuellement */

.hidden {

  display: none;

}



.disabled {

  background-color: #ccc;

  display: none;

}



/* Styles pour l'en-tête de page */

.headerPage {

  text-align: right;

