  --shadow-color-cfpv: #de209360;



  --font-size: 1.5em;

  --paragraph-margin: 10px;

  --element-margin: 5px;



  --element-padding: 5px;



  --height-tpi: 145px;

  --height-header: 90px;



  --grid-gap: 30px;

}



body {

  position: relative;

  font-family: Arial, Helvetica, sans-serif;

  padding: 15px;

}



.hidden {

  opacity: 0;

  transition: opacity 0.3s ease-in-out;

  pointer-events: none;

  /* Pour empêcher les clics sur l'en-tête masqué */

  position: fixed;

  /* Assurez-vous que l'en-tête masqué reste en place */

  top: -100px;

  /* Déplacez l'en-tête masqué hors de l'écran */

  left: 0;

  right: 0;

}



.title,

.demo {

  margin: 0;

  font-size: 28px;

  text-transform: capitalize;

  font-weight: bold;

  background-image: linear-gradient(to left,

      var(--accent-color-etml),

      var(--accent-color-cfpv));

  -webkit-background-clip: text;

  background-clip: text;

  color: transparent;

}



.demo:before {

  content: "Version de démonstration";

  /* Cela va forcer le contenu à apparaître sur une nouvelle ligne */

  position: absolute;

  top: 40px;

  right: 70px;

  font-size: 10px;

  color: white;

  background: #777;

  padding: 8px;

  border-radius: 5px;

  font-weight: bold;

  z-index: 100;

}



h3 {

  text-align: center;

  font-size: 2em;

  font-weight: bolder;

  margin-top: 8px;

  margin-bottom: 2px;

}



h4 {

  text-align: center;

  font-size: 1.7em;

  margin-top: 2px;

}



p {

  margin: 0;

  padding: 0;

}



/* Contient les éléments avec les classes demo et filters, ainsi que welcom */

.header-soutenance {

  position: fixed;

  top: 15px;

  width: 100%;

  display: grid;

  grid-template-columns: auto auto;

  /* Divise en deux colonnes */

  grid-template-rows: auto auto;

  /* Divise en deux lignes */

}



/* Classe pour le message de bienvenue */

.welcom {

  grid-column: 1 / span 2;

  /* Prend toute la largeur des deux colonnes */

  grid-row: 2;

  /* Se trouve dans la deuxième ligne */

  justify-content: start;

  /* Aligne le contenu sur le côté gauche */

  margin-top: 10px;

}



/* Classe pour les filtres */

.filters {

  grid-column: 2;

  /* Se trouve dans la deuxième colonne */

  grid-row: 1;

  /* Se trouve dans la première ligne */

  gap: 5px;

  /* Espacement entre les éléments enfants */

}



.filters select {

  height: 30px;

  margin-right: 15px;

  border: none;

  font-size: 16px;

  padding: 3px;

  background-color: transparent;

}



.btnFilters {

  height: 30px;

  background-color: #f2f2f2;

  /* Couleur de fond blanc */

  border: none;

  border-radius: 5px;

  padding: 3px 8px;

  /* Remplissage interne */

  font-size: 1.2em;

  /* Taille de police */

  font-weight: bold;

  cursor: pointer;

  /* Curseur de la souris en forme de main */

  transition: background-color 0.3s, color 0.3s;

  /* Transition fluide */

}



.btnFilters.active {

  background-color: #777;

  /* Couleur de fond bleue */

  color: white;

  /* Couleur du texte blanc */

}



.btnFilters:hover {

  filter: opacity(70%);

}



/* Styles spécifiques des classes et sélecteurs */

.soutenances {

  margin-top: 90px;

  background-color: white;

  margin-bottom: 50px;



}



.soutenances.filterActive {

  margin-left: 46px;

}



.dataGrid {

  display: grid;

  grid-template-columns: auto auto;

  justify-content: center;

  align-content: center;

  /* le zoom n'est pas pris en compte dans firefox */

  /* zoom: 0.477; */

}



.horairesBox {

  display: grid;

  /*  var(--height-tpi) */

  grid-template-rows: auto;

  font-size: var(--font-size);

  margin-top: calc(var(--height-header) + var(--element-padding));

  margin-right: 15px;

  background-color: white;

}



[class^="horaire_"] {

  display: flex;

  /*start - end */

  /*flex-direction: row;*/

  /*

  start

  - 

  end

  */

  flex-direction: column;

  text-align: center;



  margin-left: 0;

  margin-top: 15px;

  gap: 5px;

}



.startTime,

.endTime {

  margin-top: var(--element-margin-top);

}



.salles-container {

  display: flex;

  flex-direction: row;

  gap: var(--grid-gap);

}



.salles-container-smartphone {

  display: flex;

  flex-direction: column;

  gap: var(--grid-gap);

}



[class^="salle ETML"] {

  position: relative;

  border: 2px solid var(--accent-color-etml);

  border-radius: 8px;

  display: grid;



  grid-template-rows: var(--height-header) 155px;

  /* Taille fixe pour la première et la deuxième ligne */

  grid-auto-rows: min-content;

  /* Les lignes suivantes s'adaptent au contenu si celui-ci dépasse la taille spécifiée */



  padding-bottom: var(--element-padding);

}



[class^="salle CFPV"] {

  position: relative;

  border: 2px solid var(--accent-color-cfpv);

  border-radius: 8px;

  display: grid;

  grid-template-rows: var(--height-header) 155px;

  grid-auto-rows: min-content;

  /* Les lignes suivantes s'adaptent au contenu si celui-ci dépasse la taille spécifiée */

  padding-bottom: var(--element-padding);

}



.ETML {

  background-color: var(--bg-color-etml);

}



.CFPV {

  background-color: var(--bg-color-cfpv);

}



.ETML [class^="header_"] {

  width: 100%;

  border-radius: 5px 5px 0 0;

  background-color: var(--accent-color-etml);

  color: white;

  margin: 0 auto;

  grid-row-start: 1;

  grid-row-end: 2;

}



.CFPV [class^="header_"] {

  width: 100%;

  border-radius: 5px 5px 0 0;

  background-color: var(--accent-color-cfpv);

  color: white;

  margin: 0 auto;

  grid-row-start: 1;

  grid-row-end: 2;

}



.truncated-text {

  display: inline;

}



.tpi-data {

  position: relative;

  margin: 5px auto;

  height: var(--height-tpi);

  vertical-align: middle;

  width: 95%;

  background-color: white;

  border-radius: 5px;

  box-sizing: content-box;

  border: 1px solid transparent;

}



.ETML .tpi-data {

  box-shadow: 0 1px 3px 0 var(--shadow-color-etml);

}



.CFPV .tpi-data {

  box-shadow: 0 1px 3px 0 var(--shadow-color-cfpv);

}



.tpi-container {

  display: flex;

  flex-direction: column;

  justify-content: space-evenly;

  height: 100%;

  margin-left: 15px;

  /*var(--element-margin);*/

}



.ETML .tpi-data:hover {

  border: 1px solid var(--accent-color-etml);

}



.CFPV .tpi-data:hover {

  border: 1px solid var(--accent-color-cfpv);

}



.tpi-entry {

  display: grid;

  grid-template-columns: 65px 195px 75px;

  align-items: center;

  white-space: nowrap;

  font-size: 16px;

  z-index: 0;

}



.tpi-expert1,

.tpi-expert2,

.tpi-boss {

  line-height: 2;

  white-space: nowrap;

}



.tpi-entry.tpi-candidat {

  display: block;

  font-weight: bolder;

  line-height: 2.1;

  margin-bottom: 5px;

  white-space: nowrap;

  /* Empêche le texte de se retourner à la ligne */

  overflow: hidden;

  /* Masque tout texte dépassant de la zone délimitée */

  text-overflow: ellipsis;

  /* Ajoute des points de suspension (...) à la fin du texte tronqué */

}



.site {

  display: none;

  position: absolute;

  top: 5px;

  right: 5px;

  color: #eee;

}



/* Styles pour les boutons d'actions */

.action-buttons {

  white-space: nowrap;

  /* Espacement entre les boutons */

  position: relative;

  right: 10px;

}



.action-buttons button {

  /* border: 1px solid #ccc; */

  border: none;

  border-radius: 5px;

  cursor: pointer;

  background-color: transparent;

  transition: all 0.3s ease;

  width: 26px;

  height: 26px;

}



/* Styles pour les boutons validés */

.button-true {

  color: #00ff08;

  /* Texte vert pour bouton validé */

  font-weight: bold;

}



/* Styles pour les boutons non validés */

.button-false {

  color: #f44336;

  /* Texte rouge pour bouton non validé */

  font-weight: bold;

}



/* Styles pour les boutons de proposition avec des valeurs */

.button-has-values {

  color: #007bff;

  /* Texte bleu pour bouton avec valeurs */

}



/* Styles pour les boutons de proposition vides */

.button-empty {

  color: #888;

  /* Texte gris pour bouton vide */

}



/* Styles pour les boutons d'acceptation OK */

.button-accept-ok {

  color: #4caf50;



  /* Texte vert pour bouton OK */

}



/* Styles pour les boutons d'acceptation X */

.button-accept-x {

  color: #f44336;

  /* Texte rouge pour bouton X */

}



/* Styles pour les boutons de proposition avec valeurs '-' */

.button-proposition-values {

  color: #007bff;

  /* Texte bleu pour bouton proposition avec valeurs */

}



/* Styles pour les boutons de proposition avec valeurs '?' */

.button-proposition-emoji {

  font-size: 20px;

  /* Taille de police pour l'emoji */

}



.action-buttons button:hover {

  opacity: 0.8;

  background-color: transparent;

}



.action-buttons button:focus {

  outline: none;

  box-shadow: 0 0 0 2px rgba(100, 4, 234, 0.5);

}



.popup-container {

  position: fixed;

  top: 50%;

  left: 50%;

  transform: translate(-50%, -50%);

  width: 45vw;

  max-width: 60vw;

  background-color: white;

  padding: 20px;

  box-shadow: 0 0.5vh 1.5vw rgba(0, 0, 0, 0.3);

  z-index: 9;

  border-radius: 5px;

}



.popup {

  display: flex;

  flex-direction: column;

}



.popup span {

  margin: 0 auto;

}



.popup h3 {

  margin-bottom: 15px;

}



.popup input[type="date"],

.popup select {

  box-sizing: border-box;

  padding: 1.2vh;

  margin-bottom: 10px;

  border: 0.1vh solid #ccc;

  border-radius: 5px;

  width: 100%;

}



.popup button {

  width: 18vw;

  padding: 10px;

  margin-bottom: 10px;

  background-color: var(--accent-color-etml);

  color: white;

  border: none;

  border-radius: 5px;

  cursor: pointer;

  transition: background-color 0.3s ease;

}



.popup button:hover {

  background-color: var(--accent-color-cfpv);

}



.popup button:disabled {

  background-color: #ccc;

  cursor: not-allowed;

}



.popup h4 {

  margin-bottom: 1vh;

  font-size: var(--font-size);

  color: #333;

  text-align: left;

  text-decoration: underline;

}



.popup ul {

  list-style-type: circle;

  padding: 0;

}



.popup ul li {

  margin-bottom: 5px;

  margin-left: 5vw;

}



#btnAddDate {

  box-sizing: content-box;

  align-self: flex-end;

}



#btnSave {

  background-color: var(--accent-color-cfpv);

  margin-right: 20px;

}



#btnClose {

  background-color: var(--accent-color-etml);

}



.ETML .time-label {

  font-size: 0.8rem;

  position: absolute;

  top: 27px;

  right: 19px;

  font-weight: 600;

  background-color: var(--shadow-color-etml);

  padding: 2px;

  border-radius: 5px;

}



.CFPV .time-label {

  font-size: 0.8rem;

  position: absolute;

  top: 27px;

  right: 19px;

  font-weight: 600;

  background-color: var(--shadow-color-cfpv);

  padding: 2px;

  border-radius: 5px;

}



.header-row {

  display: none;

}



.no-filter {

  display: none;

}



.gris {

  color: #969595;

  /* Couleur du texte grisé */

  background-color: #e5e3e528;

  /* Couleur de fond grisé */

  pointer-events: none;

  /* Désactiver les événements de pointer */

  opacity: 0.6;

  /* Opacité pour donner un effet de gris */

}



.stabilo {

  position: relative;

}



.stabilo::after {

  content: "";

  display: block;

  width: 95%;

  height: 100%;

  position: absolute;

  top: -3px;

  left: -5px;

  padding: 3px;

  background-color: #ffee03d5;

  z-index: -1;

  border-radius: 5px;

}



/* 

  #region smartphone

*/

.message-smartphone {

  background-color: #e71c1ce1;

  color: white;

  padding: 10px 15px;

  margin-bottom: 10px;

  text-align: center;

  z-index: 99;

}



button.smartphone {

  text-align: center;

  color: white;

  font-size: 12px;

  font-weight: bold;

  height: 50px;

  width: 90px;



  margin-bottom: 10px;

  padding: 10px 15px;



  border: none;

  border-radius: 8px;

  background-color: var(--accent-color-cfpv);

}



button.smartphone:nth-child(even) {

  background-color: var(--accent-color-etml);

  /* Couleur de fond pour les boutons pairs */

}



.filters-smartphone {

  display: flex;

  flex-direction: column;

  justify-content: space-between;

  align-items: center;

}



/*#endregion*/



/*  #region PRINT  Styles appliqués uniquement lors de l'impression */



@media print {



  @page {

    size: A4 landscape;

    margin: 0;

    zoom: 0.56;

  }



  :root {

    --height-tpi: 105px;

  }



  body {

    padding: 0;

    margin: 0 auto;

  }



  #header *,

  .buttonDelete {

    display: none;

  }



  h1 {

    font-size: 14pt;

    text-align: center;

    margin-top: 0;

    margin-bottom: 1px;

    color: var(--accent-color-etml);

  }



  h3 {

    font-size: 12pt;

    margin-top: 8px;

    height: 1.1;

  }



  h4 {

    font-size: 11pt;

    margin-top: 0;

    margin-bottom: 25px;

  }



  .demo,

  .welcom,

  .btniCal,

  footer {

    display: none;

  }



  /* Crée une ligne d'en-tête pour le tableau */

  .header-row {

    width: 100%;

    display: flex;

    margin-top: -15px;

    margin-bottom: 12px;

    font-size: 11pt;

  }



  .header-cell {

    display: inline;

    font-weight: bold;

    /* Met le texte en gras */

    text-align: center;

    /* Centre le texte */

    width: 175px;

    padding: 1px;

    margin-right: 12px;

  }



  .horairesBox,

  .action-buttons,

  .filters,

  h1::before {

    display: none;

    /* Cache les éléments non nécessaires à l'impression */

  }



  [class^="salle"] {

    display: table;

    /* Chaque salle est transformée en tableau */

    width: auto;

    /* Utilise la pleine largeur */

    margin-bottom: 20px;

    /* Espacement entre les salles */

    break-inside: avoid-column;

  }



  [class^="header_"] {

    display: table-header-group;

    /* L'en-tête devient l'en-tête du tableau */

    position: relative;

    /* Positionnement relatif pour l'élément parent */

    font-weight: bold;

    /* Met le texte en gras */

    text-align: center;

    /* Centre le texte */

  }



  .soutenances {

    margin: 0;

  }



  .salle.CFPV,

  .salle.ETML {

    margin: 0 auto;

    max-height: 297mm;

    page-break-after: always;

    -webkit-page-break-after: always;

    /* Chrome, Safari */

    -moz-page-break-after: always;

    /* Firefox */

    -o-page-break-after: always;

    /* Opera */

  }



  .tpi-container {

    display: table-row;

    /* Chaque conteneur de TPI est une ligne de tableau */

    height: auto;

  }



  .tpi-entry {

    display: table-cell;

    vertical-align: middle;

    padding: 8px;

    height: 40px;

    overflow: hidden;

    text-overflow: ellipsis;

    text-align: center;

    width: 175px;

    border: none;

    font-size: 12pt;

  }



  .no-filter {

    display: block;

    padding: 5px;

    margin-top: 5px;

    margin-left: 22px;

  }



  .site {

    display: block;

    z-index: 100;

    font-weight: 700;

  }



  .tpi-expert1,

  .tpi-expert2,

  .tpi-boss {

    font-size: 0;

    /* Cache le texte en réduisant la taille de la police à 0 */

  }



  .tpi-expert1 span,

  .tpi-expert2 span,

  .tpi-boss span {

    font-size: 1rem;

    /* Rétablit la taille normale pour le texte visible */

  }



  .ETML .tpi-data {

    border: none;

    box-shadow: none;

    width: 100%;

  }



  .CFPV .tpi-data {

    border: none;

    box-shadow: none;

    width: 100%;

  }



  .tpi-data:not(:last-child) {

    border-bottom: 1px solid #aba9a9;

    /* Bordure en bas pour séparer les lignes */

  }



  .tpi-data:nth-child(odd) {

    background-color: #fef1fe;

    /* Couleur de fond pour les lignes impaires */

  }



  /* Pour aligner les noms des candidats */

  .tpi-entry.no-buttons span.nameTpi {

    padding: 5px 0;

    /* Ajoute de l'espace au-dessus et en dessous du nom */

  }

}



/* #endregion */



.btniCal {

  position: absolute;

  top: 3px;

  right: 12px;

  font-size: 16px;

  background-color: transparent;

  border: none;

  z-index: 1;

