  width: 80vw;

  justify-content: center;

}



.remaque textarea {

  background-color: #daedfcb0;

  margin-bottom: 20px;

}



/* Styles spécifiques pour les inputs questions */

[id^='input_A'],

[id^='input_C'] {

  width: 90%;

  margin: 5px 0 auto;

}



input[type='tel'],

input[type='email'],

input[type='text'],

input[type='number'],

textarea {

  padding: 5px;

  border: 1px solid #ccc;

  border-radius: 5px;

  outline: none;

  -moz-appearance: textfield;

  -webkit-appearance: textfield;

  appearance: textfield;

  box-sizing: border-box;

  resize: none;

  font-size: 14px;

}



input[id^='input'][id$='_0'] {

  /* Styles pour les éléments <input> avec ID commençant par 'input' et se terminant par '_0' */

  width: calc(100% - 53px);

}



input[type='number'] {

  text-align: center;

}



input[type='number']:invalid {

  border-color: red;

}



input[type='number']:invalid::after {

  content: 'Veuillez entrer une valeur entre 0 et 3';

  display: block;

  color: red;

  font-size: 0.8rem;

  margin-top: 0.2rem;

}



textarea:focus,

input[type='number']:focus {

  border-color: #007bff;

  /* Couleur de la bordure lorsqu'il est en focus */

}



/* --------------- Région : Styles pour la mise en page --------------- */



/* Styles pour les colonnes avec différentes longueurs */

.col-1 {

  width: 30px;

  /* Longueur pour contenir "A20" */

}



.col-2 {

  width: 45%;

  /* Longueur dynamique */

}



.btn_question {

  width: 56px;

  display: inline-flex;

  position: absolute;

  transform: translateY(7px);

}



.btn_questionMinus,

.btn_questionAdd {

  border: none;

  margin-left: 3px;

  padding: 4px;

  width: 25px;

  font-weight: bold;

  color: white;

  font-size: 14px;

}



.btn_Selected {

  white-space: nowrap;

  background-color: #cba99b; /* Couleur de fond plus claire */

