# Exemple de configuration serveur (à copier dans .env)
# Identifiants admin en clair pour le dev local.
# L'API les convertit en mémoire au moment de l'authentification.
AUTH_USER_PLAIN=
AUTH_PASS_PLAIN=

# Variante production ou CI: hashes bcrypt pré-calculés
AUTH_USER_HASH=
AUTH_PASS_HASH=

# Mode démo (true ou false)
REACT_APP_DEBUG=true

# Active les controles admin dans l'interface React.
# Ne remplace pas l'authentification backend.
REACT_APP_ENABLE_ADMIN_UI=false

# Secret legacy utilise par TpiTracker pour chiffrer/dechiffrer les mots de passe.
# Comme il est injecte dans le bundle frontend, il reste visible par le client.
REACT_APP_TPI_TRACKER_SECRET=

# Secret JWT pour les magic links et sessions web
JWT_SECRET=

# Duree de validite des magic links en heures
MAGIC_LINK_VOTE_EXPIRY_HOURS=168
MAGIC_LINK_SOUTENANCE_EXPIRY_HOURS=96

# Envoi email automatique (désactivé côté UI tant que le flux n'est pas validé)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TPI Organizer <noreply@tpi-organizer.ch>

# Secret optionnel dédié aux sessions admin de l'application
AUTH_SESSION_SECRET=

# Bypass explicite de l'auth planning en local seulement
SKIP_PLANNING_AUTH=false

# Bypass explicite de l'auth admin legacy en local seulement
SKIP_APP_AUTH=false

# URI Mongo optionnelle pour simplifier la configuration locale
DB_URI=

# Sécurité serveur
CORS_ORIGIN=http://localhost:3000
JSON_BODY_LIMIT=10mb
TPI_EVAL_PDF_PATH=./models/mEvalV3.pdf

# Publication statique des défenses
# Racine FTP visible publiquement, par exemple le dossier public_html de l'hébergement.
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=

# Sous-dossier FTP de la publication statique. Laisser vide publie dans soutenances-{year}
# sous FTP_REMOTE_DIR. Peut contenir {year}.
# Pour publier directement dans FTP_REMOTE_DIR, utiliser "." et STATIC_PUBLIC_PATH=/.
FTP_STATIC_REMOTE_DIR=

# URL publique du domaine et chemin public. Laisser STATIC_PUBLIC_PATH vide utilise /soutenances-{year}/.
STATIC_PUBLIC_BASE_URL=https://tpi26.ch
STATIC_PUBLIC_PATH=
