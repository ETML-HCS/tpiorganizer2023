{
  "name": "tpiorganizer2023",
  "version": "26.5.2",
  "private": true,
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "mongoose": "^9.6.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "react-toastify": "^11.1.0"
  },
  "scripts": {
    "start": "cross-env REACT_APP_DEBUG=true vite --open",
    "build": "cross-env REACT_APP_DEBUG=false vite build",
    "server": "node ./API/serverAPI.js",
    "serve": "vite preview",
    "client": "cross-env REACT_APP_DEBUG=true vite --open",
    "test": "jest",
    "test:api": "node --test API/utils/availability.test.js API/tests/*.test.js",
    "check-env-prod": "node ./scripts/check-prod-config.js",
    "backend": "cross-env PORT=5001 REACT_APP_DEBUG=true node ./API/serverAPI.js",
    "backend:watch": "cross-env PORT=5001 REACT_APP_DEBUG=true node --watch ./API/serverAPI.js",
    "dev": "concurrently \"npm run backend:watch\" \"npm start\"",
    "dev:5001": "concurrently \"cross-env PORT=5001 npm run backend:watch\" \"cross-env REACT_APP_DEBUG=true REACT_APP_API_URL_TRUE=http://localhost:5001 npm start\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost"
    },
    "setupFiles": [
      "<rootDir>/test/setupEnvironment.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/*.test.{js,jsx}"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/API/"
    ],
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "\\.(css|less|sass|scss)$": "<rootDir>/test/styleMock.js",
      "\\.(gif|jpg|jpeg|png|svg|webp|avif|eot|otf|ttf|woff|woff2)$": "<rootDir>/test/fileMock.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-jest": "^30.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^7.0.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "vite": "^8.0.10"
  }
}
