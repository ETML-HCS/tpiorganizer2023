  "scripts": {
    "start": "cross-env REACT_APP_DEBUG=true vite --open",
    "build": "cross-env REACT_APP_DEBUG=false vite build",
    "server": "node ./API/serverAPI.js",
    "serve": "vite preview",
    "client": "cross-env REACT_APP_DEBUG=true vite --open",
    "test": "react-scripts test",
    "test:api": "node --test API/utils/availability.test.js API/tests/*.test.js",
    "eject": "react-scripts eject",
    "check-env-prod": "node ./scripts/check-prod-config.js",
    "backend": "cross-env PORT=5001 REACT_APP_DEBUG=true node ./API/serverAPI.js",
    "backend:watch": "cross-env PORT=5001 REACT_APP_DEBUG=true node --watch ./API/serverAPI.js",
    "dev": "concurrently \"npm run backend:watch\" \"npm start\"",
    "dev:5001": "concurrently \"cross-env PORT=5001 npm run backend:watch\" \"cross-env REACT_APP_DEBUG=true REACT_APP_API_URL_TRUE=http://localhost:5001 npm start\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
